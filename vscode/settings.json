{
    // DEBUG -----------------------------------------------------------
    "debug.allowBreakpointsEverywhere": true,
    // EDITOR ----------------------------------------------------------
    "editor.fontFamily": "'JetBrains Mono', 'Droid Sans Mono', 'monospace', monospace",
    "editor.formatOnSave": false,
    "editor.cursorBlinking": "solid",
    "editor.accessibilitySupport": "off",
    "editor.colorDecorators": false,
    "editor.dragAndDrop": false,
    "editor.folding": false,
    "editor.showFoldingControls": "mouseover",
    "editor.fontLigatures": false,
    "editor.fontSize": 14,
    "editor.minimap.enabled": false,
    "editor.renderWhitespace": "all",
    "editor.renderLineHighlight": "none",
    "editor.hideCursorInOverviewRuler": true,
    "editor.occurrencesHighlight": "off",
    "editor.overviewRulerBorder": false,
    "editor.rulers": [72],
    "editor.scrollBeyondLastLine": false,
    "editor.snippetSuggestions": "none",
    "editor.cursorSurroundingLines": 3,
    "editor.useTabStops": true,
    "editor.formatOnPaste": false,
    "editor.wordWrap": "off",
    "editor.wordWrapColumn": 80,
    "editor.stickyScroll.enabled": false,
    "editor.scrollbar.vertical": "auto",
    "editor.scrollbar.horizontal": "hidden",
    "editor.autoClosingBrackets": "never",
    "editor.autoClosingQuotes": "never",
    "editor.autoSurround": "never",
    "editor.autoClosingOvertype": "never",
    "editor.suggestOnTriggerCharacters": false,
    "editor.acceptSuggestionOnCommitCharacter": false,
    "editor.acceptSuggestionOnEnter": "on",
    "editor.tabCompletion": "on",
    "editor.suggestSelection": "recentlyUsed",
    "editor.quickSuggestions": {
        "other": true,
        "comments": false,
        "strings": false,
    },
    "editor.formatOnType": false,
    "editor.inlineSuggest.enabled": false,
    "editor.suggest.localityBonus": false,
    "editor.detectIndentation": false,
    "editor.pasteAs.preferences": [
        "text.plain",
    ],
    "editor.indentSize": "tabSize",
    "editor.codeActionsOnSave": {},
    "editor.largeFileOptimizations": true,
    "editor.lightbulb.enabled": "off",
    "editor.hover.enabled": "off",
    "editor.selectionHighlight": false,
    "editor.codeLens": false,
    "editor.cursorSmoothCaretAnimation": "off",
    "editor.smoothScrolling": false,
    "editor.renderControlCharacters": false,
    "editor.matchBrackets": "never",
    "editor.guides.bracketPairs": false,
    // "editor.glyphMargin": false,
    "editor.copyWithSyntaxHighlighting": false,
    "editor.foldingHighlight": false,
    "editor.guides.highlightActiveBracketPair": false,
    "editor.guides.highlightActiveIndentation": false,
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "editor.unicodeHighlight.includeStrings": false,
    "editor.unicodeHighlight.invisibleCharacters": false,
    "editor.unicodeHighlight.nonBasicASCII": false,
    "editor.inlineSuggest.syntaxHighlightingEnabled": false,
    "editor.bracketPairColorization.enabled": false,
    // "editor.parameterHints.enabled": false,
    "editor.experimentalWhitespaceRendering": "off",
    "editor.renderFinalNewline": "off",
    "editor.minimap.renderCharacters": false,
    "editor.inlineSuggest.edits.renderSideBySide": "never",
    "editor.experimental.treeSitterTelemetry": false,
    // WORKBENCH -------------------------------------------------------
    // "workbench.activityBar.location": "hidden",
    "workbench.statusBar.visible": false,
    "workbench.sideBar.location": "right",
    "workbench.quickOpen.preserveInput": false,
    "workbench.colorTheme": "Light Modern",
    "workbench.startupEditor": "none",
    "workbench.hover.delay": 10000,
    "workbench.layoutControl.enabled": false,
    "workbench.tips.enabled": false,
    "workbench.tree.renderIndentGuides": "none",
    "workbench.tree.enableStickyScroll": false,
    "workbench.editor.tabActionCloseVisibility": false,
    "workbench.editor.limit.enabled": true,
    "workbench.editor.limit.perEditorGroup": true,
    "workbench.editor.limit.value": 5,
    "workbench.editor.labelFormat": "medium",
    "workbench.editor.highlightModifiedTabs": false,
    "workbench.editor.showIcons": true,
    "workbench.editor.showTabs": "single",
    // "workbench.editor.showTabs": "none",
    "workbench.editor.decorations.badges": false,
    "workbench.editor.decorations.colors": false,
    "workbench.editor.enablePreview": false,
    "workbench.editor.autoLockGroups": {
        "workbench.editor.chatSession": false,
        "mainThreadWebview-simpleBrowser.view": false,
        "mainThreadWebview-browserPreview": false
    },
    "workbench.enableExperiments": false,
    "workbench.settings.enableNaturalLanguageSearch": false,
    "workbench.reduceMotion": "off",
    // FILES -----------------------------------------------------------
    "files.insertFinalNewline": false,
    "files.autoSave": "onFocusChange",
    "files.eol": "\n",
    // SIMPLE NAVIGATION -----------------------------------------------
    "editor.gotoLocation.multipleReferences": "goto",
    "editor.gotoLocation.multipleDefinitions": "goto",
    "editor.gotoLocation.multipleDeclarations": "goto",
    "editor.gotoLocation.multipleImplementations": "goto",
    "editor.gotoLocation.multipleTypeDefinitions": "goto",
    // EXPLORER --------------------------------------------------------
    "explorer.openEditors.visible": 1,
    "explorer.compactFolders": false,
    "explorer.decorations.badges": false,
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*",
        "*.sqlite3": "${capture}.${extname}-*",
        "*.db3": "${capture}.${extname}-*",
        "*.sdb": "${capture}.${extname}-*",
        "*.s3db": "${capture}.${extname}-*"
    },
    "explorer.openEditors.minVisible": 0,
    "explorer.confirmDelete": true,
    "editor.semanticHighlighting.enabled": false,
    // "explorer.decorations.colors": false,
    // SEARCH ----------------------------------------------------------
    "search.quickAccess.preserveInput": true,
    "search.quickOpen.includeSymbols": false,
    "search.quickOpen.history.filterSortOrder": "recency",
    "search.followSymlinks": false,
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true,
        "**/bower_components/**": true,
        "**/dist/**": true,
        "**/build/**": true
    },
    // TELEMETRY -------------------------------------------------------
    "telemetry.telemetryLevel": "off",
    "telemetry.feedback.enabled": false,
    "telemetry.editStats.details.enabled": false,
    "telemetry.editStats.showStatusBar": false,
    // TERMINAL --------------------------------------------------------
    "terminal.integrated.defaultLocation": "editor",
    "terminal.integrated.shellIntegration.enabled": false,
    "terminal.integrated.shellIntegration.decorationsEnabled": "never",
    "terminal.integrated.stickyScroll.enabled": false,
    "terminal.integrated.suggest.enabled": false,
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "terminal.integrated.defaultProfile.linux": "bash",
    "accessibility.signals.terminalBell": {
        "sound": "off",
        "announcement": "off",
    },
    "terminal.integrated.enableVisualBell": true,
    "terminal.integrated.fontLigatures.enabled": false,
    "terminal.integrated.sendKeybindingsToShell": true,
    "terminal.integrated.tabs.location": "left",
    "terminal.integrated.gpuAcceleration": "on",
    "terminal.integrated.enableImages": false,
    "terminal.integrated.cursorBlinking": false,
    "terminal.integrated.tabs.enableAnimation": false,
    "terminal.integrated.customGlyphs": false,
    // WINDOW ----------------------------------------------------------
    "window.newWindowProfile": "Default",
    "window.commandCenter": false,
    "window.clickThroughInactive": false,
    "window.newWindowDimensions": "maximized",
    "window.title": "${dirty}${separator}${rootName}${separator}${activeRepositoryBranchName}",
    // EXTENSIONS ------------------------------------------------------
    "extensions.ignoreRecommendations": true,
    "extensions.autoUpdate": "off",
    "extensions.autoCheckUpdates": false,
    // VERSION CONTROL -------------------------------------------------
    "git.autofetch": false,
    "git.showInlineOpenFileAction": false,
    "git.autorefresh": true,
    "git.decorations.enabled": true,
    "git.openRepositoryInParentFolders": "never",
    "git.blame.editorDecoration.enabled": false,
    "git.blame.statusBarItem.enabled": false,
    "git.ignoreMissingGitWarning": true,
    "merge-conflict.autoNavigateNextConflict.enabled": false,
    "diffEditor.renderSideBySide": false,
    "diffEditor.renderMarginRevertIcon": false,
    "diffEditor.renderIndicators": false,
    "diffEditor.renderGutterMenu": false,
    // CHAT ------------------------------------------------------------
    "chat.extensionTools.enabled": false,
    "chat.focusWindowOnConfirmation": false,
    "chat.commandCenter.enabled": false,
    "chat.agent.enabled": false,
    "chat.math.enabled": false,
    "chat.agent.thinkingStyle": "collapsed",
    "inlineChat.accessibleDiffView": "off",
    // PYTHON ----------------------------------------------------------
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
        },
        "editor.rulers": [88],
        "files.insertFinalNewline": true,
    },
    "python.terminal.activateEnvironment": true,
    "python.terminal.shellIntegration.enabled": true,
    "python.terminal.activateEnvInCurrentTerminal": true,
    "python.languageServer": "Pylance",
    "python.analysis.typeCheckingMode": "standard",
    "python.analysis.typeEvaluation.deprecateTypingAliases": true,
    "python.analysis.diagnosticSeverityOverrides": {
        "reportGeneralTypeIssues": false
    },
    "python.analysis.completeFunctionParens": false,
    "python.createEnvironment.trigger": "off",
    "python.analysis.reportExtraTelemetry": false,
    "python.analysis.addHoverSummaries": false,
    "python.analysis.ignore": [
        "**/*.py"
    ],
    "python.analysis.autoImportCompletions": true,
    "python.analysis.autoSearchPaths": false,
    "python.analysis.importFormat": "absolute",
    "python.experiments.enabled": false,
    "python.testing.autoTestDiscoverOnSaveEnabled": false,
    // GOLANG ----------------------------------------------------------
    "[go]": {
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        },
        "editor.defaultFormatter": "golang.go",
        "editor.rulers": [88]
    },
    "go.formatTool": "gofmt",
    "go.delveConfig": {
        "debugAdapter": "dlv-dap",
        "dlvFlags": [
            "--only-same-user=false"
        ]
    },
    "gopls": {
        "ui.semanticTokens": true,
        "formatting.gofumpt": true
    },
    // SQL -------------------------------------------------------------
    "pgsql.showConnectionStatusLens": false,
    "pgsql.intelliSense.enableIntelliSense": true,
    "pgsql.copilot.enable": false,
    "pgsql.copilot.accessMode": "ro",
    "pgsql.copilot.modelOptions": {},
    "sql-formatter.dialect": "pl/sql",
    "[sql]": {
        "editor.defaultFormatter": "adpyke.vscode-sql-formatter",
        "editor.formatOnSave": true,
    },
    // OTHER -----------------------------------------------------------
    // "problems.decorations.enabled": true,
    "outline.icons": false,
    "scm.compactFolders": false,
    "notebook.consolidatedOutputButton": false,
    "notebook.globalToolbar": false,
    "notebook.globalToolbarShowLabel": "never",
    "breadcrumbs.enabled": false,
    "breadcrumbs.icons": false,

    "cSpell.language": "en,ru",
    "vsicons.dontShowNewVersionMessage": true,
    "update.showReleaseNotes": false,
    "database-client.autoSync": false,
    "database-client.telemetry.usesOnlineServices": false,
    "docker.lsp.telemetry": "off",
    "autoDocstring.docstringFormat": "sphinx-notypes",
    "files.exclude": {
        "**/node_modules": true,
        "**/bower_components": true,
        "**/dist": true,
        "**/build": true,
        "**/.git": true
    },
    "typescript.validate.enable": false,
    "javascript.validate.enable": false,
    "window.zoomLevel": 2,
    "pgsql.serverGroups": [
        {
            "name": "Servers",
            "id": "9E93DADE-06C1-4205-B17C-2F3582BBC91C",
            "isDefault": true
        }
    ],
    "terminal.integrated.commandsToSkipShell": [
        "kilo-code.new.agentManagerOpen",
        "kilo-code.new.agentManager.showTerminal"
    ],

}
